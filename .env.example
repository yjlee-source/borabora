# Local development default. For Vercel Postgres, replace this with the Postgres URL
# and switch prisma/schema.prisma datasource provider from sqlite to postgresql.
DATABASE_URL="file:./dev.db"

# Required for encrypted hotel-chain credentials.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# Optional: remote Chromium endpoint, for example Browserless.
BROWSERLESS_WS_ENDPOINT=""

# Optional single-user guard for API requests. Vercel Deployment Protection is still recommended.
PERSONAL_ACCESS_TOKEN=""
